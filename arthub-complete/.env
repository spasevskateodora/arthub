# Server
PORT=3000

# MongoDB — local (used in Docker)
MONGO_URI=mongodb://mongo:27017/arthub

# MongoDB — production (MongoDB Atlas)
# MONGO_URI=mongodb+srv://youruser:yourpassword@cluster.mongodb.net/arthub

# JWT
JWT_SECRET=arthub_secret_key_change_this

# Nodemailer (Gmail example)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password

# Environment
NODE_ENV=development
